# Port the server listens on (Railway/Render inject this automatically)
PORT=3001

# URL of the deployed frontend (your Vercel URL)
CLIENT_URL=http://localhost:3000

# JWT secret - change this to a long random string in production
JWT_SECRET=your-secret-key-change-in-production

# Ollama config (only needed if using local LLM evaluation)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llama3.1:8b
